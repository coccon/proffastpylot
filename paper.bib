
@article{Hase:2015,
  title = {Application of portable {FTIR} spectrometers for detecting greenhouse gas emissions of the major city {Berlin}},
  volume = {8},
  issn = {1867-1381},
  url = {https://amt.copernicus.org/articles/8/3059/2015/},
  doi = {10.5194/amt-8-3059-2015},
  abstract = {{\textless}p{\textgreater}{\textless}strong class="journal-contentHeaderColor"{\textgreater}Abstract.{\textless}/strong{\textgreater} Five portable Bruker EM27/SUN FTIR (Fourier transform infrared) spectrometers have been used for the accurate and precise observation of column-averaged abundances of CO$_{\textrm{2}}$ and CH$_{\textrm{4}}$ around the major city Berlin. In the work by Frey et al. (2015), a calibration procedure is developed and applied to the set of spectrometers used for the Berlin campaign. Here, we describe the observational setup of the campaign and aspects of the data analysis, and we present the recorded time series of XCH$_{\textrm{4}}$ and XCO$_{\textrm{2}}$. We demonstrate that the CO$_{\textrm{2}}$ emissions of Berlin can be clearly identified in the observations. A simple dispersion model is applied which indicates a total strength of the Berlin source of about 0.8 t CO$_{\textrm{2}}$ s$^{\textrm{−1}}$. In the Supplement of this work, we provide the measured data set and auxiliary data. We hope that the model community will exploit this unique data set for state-of-the art inversion studies of CO$_{\textrm{2}}$ and CH$_{\textrm{4}}$ sources in the Berlin area.{\textless}/p{\textgreater}},
  language = {English},
  number = {7},
  urldate = {2021-03-19},
  journal = {Atmospheric Measurement Techniques},
  author = {Hase, F. and Frey, M. and Blumenstock, T. and Groß, J. and Kiel, M. and Kohlhepp, R. and Mengistu Tsidu, G. and Schäfer, K. and Sha, M. K. and Orphal, J.},
  month = jul,
  year = {2015},
  note = {Publisher: Copernicus GmbH},
  keywords = {city campaign},
  pages = {3059--3068},
  file = {Full Text PDF:/home/lena/Zotero/storage/8MDLMDQP/Hase et al. - 2015 - Application of portable FTIR spectrometers for det.pdf:application/pdf;Snapshot:/home/lena/Zotero/storage/KT2N6PA5/2015.html:text/html},
}

@article{Vogel:2019,
  title = {{XCO}$_{\textrm{2}}$ in an emission hot-spot region: the {COCCON} {Paris} campaign 2015},
  volume = {19},
  issn = {1680-7316},
  shorttitle = {{XCO}$_{\textrm{2}}$ in an emission hot-spot region},
  url = {https://acp.copernicus.org/articles/19/3271/2019/},
  doi = {10.5194/acp-19-3271-2019},
  abstract = {{\textless}p{\textgreater}{\textless}strong class="journal-contentHeaderColor"{\textgreater}Abstract.{\textless}/strong{\textgreater} Providing timely information on urban greenhouse gas (GHG) emissions and their trends to stakeholders relies on reliable measurements of atmospheric concentrations and the understanding of how local emissions and atmospheric transport influence these observations.{\textless}/p{\textgreater} {\textless}p{\textgreater}Portable Fourier transform infrared (FTIR) spectrometers were deployed at five stations in the Paris metropolitan area to provide column-averaged concentrations of {\textless}span class="inline-formula"{\textgreater}CO$_{\textrm{2}}${\textless}/span{\textgreater} ({\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater}) during a field campaign in spring of 2015, as part of the Collaborative Carbon Column Observing Network (COCCON). Here, we describe and analyze the variations of {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} observed at different sites and how they changed over time. We find that observations upwind and downwind of the city centre differ significantly in their {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} concentrations, while the overall variability of the daily cycle is similar, i.e. increasing during night-time with a strong decrease (typically 2–3\&thinsp;ppm) during the afternoon.{\textless}/p{\textgreater} {\textless}p{\textgreater}{\textless}span id="page3272"/{\textgreater}An atmospheric transport model framework (CHIMERE-CAMS) was used to simulate {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} and predict the same behaviour seen in the observations, which supports key findings, e.g. that even in a densely populated region like Paris (over 12 million people), biospheric uptake of {\textless}span class="inline-formula"{\textgreater}CO$_{\textrm{2}}${\textless}/span{\textgreater} can be of major influence on daily {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} variations. Despite a general offset between modelled and observed {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater}, the model correctly predicts the impact of the meteorological parameters (e.g. wind direction and speed) on the concentration gradients between different stations. When analyzing local gradients of {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} for upwind and downwind station pairs, those local gradients are found to be less sensitive to changes in {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} boundary conditions and biogenic fluxes within the domain and we find the model–data agreement further improves. Our modelling framework indicates that the local {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} gradient between the stations is dominated by the fossil fuel {\textless}span class="inline-formula"{\textgreater}CO$_{\textrm{2}}${\textless}/span{\textgreater} signal of the Paris metropolitan area. This further highlights the potential usefulness of {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} observations to help optimize future urban GHG emission estimates.{\textless}/p{\textgreater}},
  language = {English},
  number = {5},
  urldate = {2021-03-19},
  journal = {Atmospheric Chemistry and Physics},
  author = {Vogel, Felix R. and Frey, Matthias and Staufer, Johannes and Hase, Frank and Broquet, Grégoire and Xueref-Remy, Irène and Chevallier, Frédéric and Ciais, Philippe and Sha, Mahesh Kumar and Chelin, Pascale and Jeseck, Pascal and Janssen, Christof and Té, Yao and Groß, Jochen and Blumenstock, Thomas and Tu, Qiansi and Orphal, Johannes},
  month = mar,
  year = {2019},
  note = {Publisher: Copernicus GmbH},
  keywords = {city campaign},
  pages = {3271--3285},
  file = {Full Text PDF:/home/lena/Zotero/storage/ALFLSDGK/Vogel et al. - 2019 - XCO2 in an emission hot-spot region th.pdf:application/pdf;Snapshot:/home/lena/Zotero/storage/YQJAU5EK/2019.html:text/html},
}

@article{Frey:2019,
  title = {Building the {COllaborative} {Carbon} {Column} {Observing} {Network} ({COCCON}): long-term stability and ensemble performance of the {EM27}/{SUN} {Fourier} transform spectrometer},
  volume = {12},
  issn = {1867-1381},
  shorttitle = {Building the {COllaborative} {Carbon} {Column} {Observing} {Network} ({COCCON})},
  url = {https://amt.copernicus.org/articles/12/1513/2019/},
  doi = {10.5194/amt-12-1513-2019},
  abstract = {{\textless}p{\textgreater}{\textless}strong class="journal-contentHeaderColor"{\textgreater}Abstract.{\textless}/strong{\textgreater} In a 3.5-year long study, the long-term performance of a mobile, solar absorption Bruker EM27/SUN spectrometer, used for greenhouse gas observations, is checked with respect to a co-located reference Bruker IFS 125HR spectrometer, which is part of the Total Carbon Column Observing Network (TCCON). We find that the EM27/SUN is stable on timescales of several years; the drift per year between the EM27/SUN and the official TCCON product is 0.02\&thinsp;ppmv for X{\textless}span class="inline-formula"{\textgreater}CO$_{\textrm{2}}${\textless}/span{\textgreater} and 0.9\&thinsp;ppbv for X{\textless}span class="inline-formula"{\textgreater}CH$_{\textrm{4}}${\textless}/span{\textgreater}, which is within the 1{\textless}span class="inline-formula"{\textgreater}\textit{σ}{\textless}/span{\textgreater} precision of the comparison, 0.6\&thinsp;ppmv for X{\textless}span class="inline-formula"{\textgreater}CO$_{\textrm{2}}${\textless}/span{\textgreater} and 4.3\&thinsp;ppbv for X{\textless}span class="inline-formula"{\textgreater}CH$_{\textrm{4}}${\textless}/span{\textgreater}. The bias between the two data sets is 3.9\&thinsp;ppmv for X{\textless}span class="inline-formula"{\textgreater}CO$_{\textrm{2}}${\textless}/span{\textgreater} and 13.0\&thinsp;ppbv for X{\textless}span class="inline-formula"{\textgreater}CH$_{\textrm{4}}${\textless}/span{\textgreater}. In order to avoid sensitivity-dependent artifacts, the EM27/SUN is also compared to a truncated IFS 125HR data set derived from full-resolution TCCON interferograms. The drift is 0.02\&thinsp;ppmv for X{\textless}span class="inline-formula"{\textgreater}CO$_{\textrm{2}}${\textless}/span{\textgreater} and 0.2\&thinsp;ppbv for X{\textless}span class="inline-formula"{\textgreater}CH$_{\textrm{4}}${\textless}/span{\textgreater} per year, with 1{\textless}span class="inline-formula"{\textgreater}\textit{σ}{\textless}/span{\textgreater} precisions of 0.4\&thinsp;ppmv for X{\textless}span class="inline-formula"{\textgreater}CO$_{\textrm{2}}${\textless}/span{\textgreater} and 1.4\&thinsp;ppbv for X{\textless}span class="inline-formula"{\textgreater}CH$_{\textrm{4}}${\textless}/span{\textgreater}, respectively. The bias between the two data sets is 0.6\&thinsp;ppmv for X{\textless}span class="inline-formula"{\textgreater}CO$_{\textrm{2}}${\textless}/span{\textgreater} and 0.5\&thinsp;ppbv for X{\textless}span class="inline-formula"{\textgreater}CH$_{\textrm{4}}${\textless}/span{\textgreater}. With the presented long-term stability, the EM27/SUN qualifies as an useful supplement to the existing TCCON network in remote areas. To achieve consistent performance, such an extension requires careful testing of any spectrometers involved by application of common quality assurance measures. One major aim of the COllaborative Carbon Column Observing Network (COCCON) infrastructure is to provide these services to all EM27/SUN operators. In the framework of COCCON development, the performance of an ensemble of 30 EM27/SUN spectrometers was tested and found to be very uniform, enhanced by the centralized inspection performed at the Karlsruhe Institute of Technology prior to deployment. Taking into account measured instrumental line shape parameters for each spectrometer, the resulting average bias across the ensemble with respect to the reference EM27/SUN used in the long-term study in X{\textless}span class="inline-formula"{\textgreater}CO$_{\textrm{2}}${\textless}/span{\textgreater} is 0.20\&thinsp;ppmv, while it is 0.8\&thinsp;ppbv for X{\textless}span class="inline-formula"{\textgreater}CH$_{\textrm{4}}${\textless}/span{\textgreater}. The average standard deviation of the ensemble is 0.13\&thinsp;ppmv for X{\textless}span class="inline-formula"{\textgreater}CO$_{\textrm{2}}${\textless}/span{\textgreater} and 0.6\&thinsp;ppbv for X{\textless}span class="inline-formula"{\textgreater}CH$_{\textrm{4}}${\textless}/span{\textgreater}. In addition to the robust metric based on absolute differences, we calculate the standard deviation among the empirical calibration factors. The resulting 2{\textless}span class="inline-formula"{\textgreater}\textit{σ}{\textless}/span{\textgreater} uncertainty is 0.6\&thinsp;ppmv for X{\textless}span class="inline-formula"{\textgreater}CO$_{\textrm{2}}${\textless}/span{\textgreater} and 2.2\&thinsp;ppbv for X{\textless}span class="inline-formula"{\textgreater}CH$_{\textrm{4}}${\textless}/span{\textgreater}. As indicated by the executed long-term study on one device presented here, the remaining empirical calibration factor deduced for each individual instrument can be assumed constant over time. Therefore the application of these empirical factors is expected to further improve the EM27/SUN network conformity beyond the scatter among the empirical calibration factors reported above.{\textless}/p{\textgreater}},
  language = {English},
  number = {3},
  urldate = {2021-07-22},
  journal = {Atmospheric Measurement Techniques},
  author = {Frey, Matthias and Sha, Mahesh K. and Hase, Frank and Kiel, Matthäus and Blumenstock, Thomas and Harig, Roland and Surawicz, Gregor and Deutscher, Nicholas M. and Shiomi, Kei and Franklin, Jonathan E. and Bösch, Hartmut and Chen, Jia and Grutter, Michel and Ohyama, Hirofumi and Sun, Youwen and Butz, André and Mengistu Tsidu, Gizaw and Ene, Dragos and Wunch, Debra and Cao, Zhensong and Garcia, Omaira and Ramonet, Michel and Vogel, Felix and Orphal, Johannes},
  month = mar,
  year = {2019},
  note = {Publisher: Copernicus GmbH},
  pages = {1513--1530},
  file = {Full Text PDF:/home/lena/Zotero/storage/ICGU5BFM/Frey et al. - 2019 - Building the COllaborative Carbon Column Observing.pdf:application/pdf;Snapshot:/home/lena/Zotero/storage/386WXMHV/2019.html:text/html},
}

@article{Tu:2020,
  title = {Intercomparison of atmospheric {CO}$_{\textrm{2}}$ and {CH}$_{\textrm{4}}$ abundances on regional scales in boreal areas using {Copernicus} {Atmosphere} {Monitoring} {Service} ({CAMS}) analysis, {COllaborative} {Carbon} {Column} {Observing} {Network} ({COCCON}) spectrometers, and {Sentinel}-5 {Precursor} satellite observations},
  volume = {13},
  issn = {1867-1381},
  url = {https://amt.copernicus.org/articles/13/4751/2020/},
  doi = {10.5194/amt-13-4751-2020},
  abstract = {{\textless}p{\textgreater}{\textless}strong class="journal-contentHeaderColor"{\textgreater}Abstract.{\textless}/strong{\textgreater} {\textless}span id="page4752"/{\textgreater}We compare the atmospheric column-averaged dry-air mole fractions of carbon dioxide ({\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater}) and methane ({\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater}) measured with a pair of COllaborative Carbon Column Observing Network (COCCON) spectrometers at Kiruna and Sodankylä (boreal areas). We compare model data provided by the Copernicus Atmosphere Monitoring Service (CAMS) between 2017 and 2019 with {\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater} data from the recently launched Sentinel-5 Precursor (S5P) satellite between 2018 and 2019. In addition, measured and modeled gradients of {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} and {\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater} ({\textless}span class="inline-formula"{\textgreater}Δ{\textless}/span{\textgreater}{\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} and {\textless}span class="inline-formula"{\textgreater}Δ{\textless}/span{\textgreater}{\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater}) on regional scales are investigated. Both sites show a similar and very good correlation between COCCON retrievals and the modeled CAMS {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} data, while CAMS data are biased high with respect to COCCON by 3.72\&thinsp;ppm ({\textless}span class="inline-formula"{\textgreater}±1.80{\textless}/span{\textgreater}\&thinsp;ppm) in Kiruna and 3.46\&thinsp;ppm ({\textless}span class="inline-formula"{\textgreater}±1.73{\textless}/span{\textgreater}\&thinsp;ppm) in Sodankylä on average. For {\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater}, CAMS values are higher than the COCCON observations by 0.33\&thinsp;ppb ({\textless}span class="inline-formula"{\textgreater}±11.93{\textless}/span{\textgreater}\&thinsp;ppb) in Kiruna and 7.39\&thinsp;ppb ({\textless}span class="inline-formula"{\textgreater}±10.92{\textless}/span{\textgreater}\&thinsp;ppb) in Sodankylä. In contrast, the S5P satellite generally measures lower atmospheric {\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater} than the COCCON spectrometers, with a mean difference of 9.69\&thinsp;ppb ({\textless}span class="inline-formula"{\textgreater}±20.51{\textless}/span{\textgreater}\&thinsp;ppb) in Kiruna and 3.36\&thinsp;ppb ({\textless}span class="inline-formula"{\textgreater}±17.05{\textless}/span{\textgreater}\&thinsp;ppb) in Sodankylä. We compare the gradients of {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} and {\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater} ({\textless}span class="inline-formula"{\textgreater}Δ{\textless}/span{\textgreater}{\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} and {\textless}span class="inline-formula"{\textgreater}Δ{\textless}/span{\textgreater}{\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater}) between Kiruna and Sodankylä derived from CAMS analysis and COCCON and S5P measurements to study the capability of detecting sources and sinks on regional scales. The correlations in {\textless}span class="inline-formula"{\textgreater}Δ{\textless}/span{\textgreater}{\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} and {\textless}span class="inline-formula"{\textgreater}Δ{\textless}/span{\textgreater}{\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater} between the different datasets are generally smaller than the correlations in {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} and {\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater} between the datasets at either site. The {\textless}span class="inline-formula"{\textgreater}Δ{\textless}/span{\textgreater}{\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater} values predicted by CAMS are generally higher than those observed with COCCON with a slope of 0.51. The {\textless}span class="inline-formula"{\textgreater}Δ{\textless}/span{\textgreater}{\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater} values predicted by CAMS are mostly higher than those observed with COCCON with a slope of 0.65, covering a larger dataset than the comparison between S5P and COCCON. When comparing CAMS {\textless}span class="inline-formula"{\textgreater}Δ{\textless}/span{\textgreater}{\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater} with COCCON {\textless}span class="inline-formula"{\textgreater}Δ{\textless}/span{\textgreater}{\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater} only in S5P overpass days (slope\&thinsp;{\textless}span class="inline-formula"{\textgreater}={\textless}/span{\textgreater}\&thinsp;0.53), the correlation is close to that between S5P and COCCON (slope\&thinsp;{\textless}span class="inline-formula"{\textgreater}={\textless}/span{\textgreater}\&thinsp;0.51). CAMS, COCCON, and S5P predict gradients in reasonable agreement. However, the small number of observations coinciding with S5P limits our ability to verify the performance of this spaceborne sensor. We detect no significant impact of ground albedo and viewing zenith angle on the S5P results. Both sites show similar situations with the average ratios of {\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater} (S5P/COCCON) of {\textless}span class="inline-formula"{\textgreater}0.9949±0.0118{\textless}/span{\textgreater} in Kiruna and {\textless}span class="inline-formula"{\textgreater}0.9953±0.0089{\textless}/span{\textgreater} in Sodankylä. Overall, the results indicate that the COCCON instruments have the capability of measuring greenhouse gas (GHG) gradients on regional scales, and observations performed with the portable spectrometers can contribute to inferring sources and sinks and to validating spaceborne greenhouse gas sensors. To our knowledge, this is the first published study using COCCON spectrometers for the validation of {\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater} measurements collected by S5P.{\textless}/p{\textgreater}},
  language = {English},
  number = {9},
  urldate = {2021-07-22},
  journal = {Atmospheric Measurement Techniques},
  author = {Tu, Qiansi and Hase, Frank and Blumenstock, Thomas and Kivi, Rigel and Heikkinen, Pauli and Sha, Mahesh Kumar and Raffalski, Uwe and Landgraf, Jochen and Lorente, Alba and Borsdorff, Tobias and Chen, Huilin and Dietrich, Florian and Chen, Jia},
  month = sep,
  year = {2020},
  note = {Publisher: Copernicus GmbH},
  pages = {4751--4771},
  file = {Full Text PDF:/home/lena/Zotero/storage/SWFB7CF8/Tu et al. - 2020 - Intercomparison of atmospheric CO2 and .pdf:application/pdf;Snapshot:/home/lena/Zotero/storage/D9D5QRJS/2020.html:text/html},
}


@article{Mermigkas:2021,
  title = {{FTIR} {Measurements} of {Greenhouse} {Gases} over {Thessaloniki}, {Greece} in the {Framework} of {COCCON} and {Comparison} with {S5P}/{TROPOMI} {Observations}},
  volume = {13},
  copyright = {http://creativecommons.org/licenses/by/3.0/},
  issn = {2072-4292},
  url = {https://www.mdpi.com/2072-4292/13/17/3395},
  doi = {10.3390/rs13173395},
  abstract = {In this work, column-averaged dry-air mole fractions of carbon dioxide (XCO2), methane (XCH4) and carbon monoxide (XCO) are presented for the first time at a mid-latitude urban station, Thessaloniki, Greece, using the Bruker EM27/SUN ground-based low-resolution Fourier Transform spectrometer operated according to the requirements of the Collaborative Carbon Column Observing Network (COCCON). Two years of measurements are presented and examined for seasonal variability. The observed XCO2 levels show the expected seasonal cycle (spring maximum, late summer minimum) with a peak-to-peak amplitude of 12 ppm, with maximum values reported for winter 2021 exceeding 416 ppm. The XCH4 values are shown to increase in the second half of the year, with autumn showing the highest mean value of 1.878 ± 0.01 ppm. The XCO levels, following anthropogenic sources, show high winter and low summer values, exhibiting a rise again in August and September with a maximum value of 114 ± 3 ppb and a minimum in summer 2020 of 76 ± 3 ppb. Additionally, methane and carbon monoxide products obtained from the TROPOspheric Monitoring Instrument (TROPOMI), Sentinel-5P space borne sensor, are compared with the ground-based measurements. We report a good agreement between products. The relative mean bias for methane and carbon monoxide are −0.073 ± 0.647\% and 3.064 ± 5.566\%, respectively. Furthermore, a 15-day running average is subtracted from the original daily mean values to provide ΔXCO2, ΔXCO and ΔXCH4 residuals, so as to identify local sources at a synoptic scale. ΔXCO and ΔXCO2 show the best correlation in the winter (R2 = 0.898, slope = 0.007) season due to anthropogenic emissions in this period of the year (combustion of fossil fuels or industrial activities), while in summer no correlation is found. ΔXCO and ΔXCH4 variations are similar through both years of measurements and have a very good correlation in all seasons including winter (R2 = 0.804, slope = 1.209). The investigation of the X-gases comparison is of primary importance in order to identify local sources and quantify the impact of these trace gases to the deregulation of earth-climate system balance.},
  language = {en},
  number = {17},
  urldate = {2022-02-17},
  journal = {Remote Sensing},
  author = {Mermigkas, Marios and Topaloglou, Chrysanthi and Balis, Dimitrios and Koukouli, Maria Elissavet and Hase, Frank and Dubravica, Darko and Borsdorff, Tobias and Lorente, Alba},
  month = jan,
  year = {2021},
  note = {Number: 17
Publisher: Multidisciplinary Digital Publishing Institute},
  keywords = {column average concentration, EM27SUN, FTIR, KIT, residuals, Thessaloniki, TROPOMI, ΔXCH$_{\textrm{4}}$, ΔXCO, ΔXCO$_{\textrm{2}}$},
  pages = {3395},
  file = {Full Text PDF:/home/lena/Zotero/storage/5UGWRRUW/Mermigkas et al. - 2021 - FTIR Measurements of Greenhouse Gases over Thessal.pdf:application/pdf;Snapshot:/home/lena/Zotero/storage/EN2LJGPZ/3395.html:text/html},
}


@article{Alberti:2022a,
  title = {Investigation of spaceborne trace gas products over {St} {Petersburg} and {Yekaterinburg}, {Russia}, by using {COllaborative} {Column} {Carbon} {Observing} {Network} ({COCCON}) observations},
  volume = {15},
  issn = {1867-1381},
  url = {https://amt.copernicus.org/articles/15/2199/2022/},
  doi = {10.5194/amt-15-2199-2022},
  abstract = {This work employs ground- and space-based observations, together with model data, to study columnar abundances of atmospheric trace gases (XH2O, XCO2, XCH4 and XCO) in two high-latitude Russian cities, St. Petersburg and Yekaterinburg. Two portable COllaborative Column Carbon Observing Network (COCCON) spectrometers were used for continuous measurements at these locations during 2019 and 2020. Additionally, a subset of data of special interest (a strong gradient in XCH4 and XCO was detected) collected in the framework of a mobile city campaign performed in 2019 using both instruments is investigated. All studied satellite products (TROPOMI, OCO-2, GOSAT, MUSICA IASI) show generally good agreement with COCCON observations. Satellite and ground-based observations at high latitudes are much sparser than at low or mid latitudes, which makes direct coincident comparisons between remote-sensing observations more difficult. Therefore, a method of scaling continuous Copernicus Atmosphere Monitoring Service (CAMS) model data to the ground-based observations is developed and used for creating virtual COCCON observations. These adjusted CAMS data are then used for satellite validation, showing good agreement in both Peterhof and Yekaterinburg. The gradients between the two study sites (ΔXgas) are similar between CAMS and CAMS-COCCON datasets, indicating that the model gradients are in agreement with the gradients observed by COCCON. This is further supported by a few simultaneous COCCON and satellite ΔXgas measurements, which also agree with the model gradient. With respect to the city campaign observations recorded in St Petersburg, the downwind COCCON station measured obvious enhancements for both XCH4 (10.6 ppb) and XCO (9.5 ppb), which is nicely reflected by TROPOMI observations, which detect city-scale gradients of the order 9.4 ppb for XCH4 and 12.5 ppb for XCO.},
  language = {English},
  number = {7},
  urldate = {2024-03-18},
  journal = {Atmospheric Measurement Techniques},
  author = {Alberti, Carlos and Tu, Qiansi and Hase, Frank and Makarova, Maria V. and Gribanov, Konstantin and Foka, Stefani C. and Zakharov, Vyacheslav and Blumenstock, Thomas and Buchwitz, Michael and Diekmann, Christopher and Ertl, Benjamin and Frey, Matthias M. and Imhasin, Hamud Kh and Ionov, Dmitry V. and Khosrawi, Farahnaz and Osipov, Sergey I. and Reuter, Maximilian and Schneider, Matthias and Warneke, Thorsten},
  month = apr,
  year = {2022},
  note = {Publisher: Copernicus GmbH},
  pages = {2199--2229},
  file = {Full Text PDF:/home/feld/Zotero_210217/storage/ZU86UR72/Alberti et al. - 2022 - Investigation of spaceborne trace gas products ove.pdf:application/pdf},
}


@article{Alberti:2022b,
  title = {Improved calibration procedures for the {EM27}/{SUN} spectrometers of the {COllaborative} {Carbon} {Column} {Observing} {Network} ({COCCON})},
  volume = {15},
  issn = {1867-1381},
  url = {https://amt.copernicus.org/articles/15/2433/2022/},
  doi = {10.5194/amt-15-2433-2022},
  abstract = {{\textless}p{\textgreater}{\textless}strong class="journal-contentHeaderColor"{\textgreater}Abstract.{\textless}/strong{\textgreater} In this study, an extension on the previously reported status of the COllaborative Carbon Column Observing Network's (COCCON) calibration procedures incorporating refined methods is presented. COCCON is a global network of portable Bruker EM27/SUN FTIR spectrometers for deriving column-averaged atmospheric abundances of greenhouse gases. The original laboratory open-path lamp measurements for deriving the instrumental line shape (ILS) of the spectrometer from water vapour lines have been refined and extended to the secondary detector channel incorporated in the EM27/SUN spectrometer for detection of carbon monoxide (CO). The refinements encompass improved spectroscopic line lists for the relevant water lines and a revision of the laboratory pressure measurements used for the analysis of the spectra. The new results are found to be in good agreement with those reported by Frey et al. (2019) and discussed in detail. In addition, a new calibration cell for ILS measurements was designed, constructed and put into service. Spectrometers calibrated since January 2020 were tested using both methods for ILS characterization, open-path (OP) and cell measurements. We demonstrate that both methods can detect the small variations in ILS characteristics between different spectrometers, but the results of the cell method indicate a systematic bias of the OP method. Finally, a revision and extension of the COCCON network instrument-to-instrument calibration factors for {\textless}span class="inline-formula"{\textgreater}XCO$_{\textrm{2}}${\textless}/span{\textgreater}, XCO and {\textless}span class="inline-formula"{\textgreater}XCH$_{\textrm{4}}${\textless}/span{\textgreater} is presented, incorporating 47 new spectrometers (of 83 in total by now). This calibration is based on the reference EM27/SUN spectrometer operated by the Karlsruhe Institute of Technology (KIT) and spectra collected by the collocated TCCON station Karlsruhe. Variations in the instrumental characteristics of the reference EM27/SUN from 2014 to 2017 were detected, probably arising from realignment and the dual-channel upgrade performed in early 2018. These variations are considered in the evaluation of the instrument-specific calibration factors in order to keep all tabulated calibration results consistent.{\textless}/p{\textgreater}},
  language = {English},
  number = {8},
  urldate = {2022-05-23},
  journal = {Atmospheric Measurement Techniques},
  author = {Alberti, Carlos and Hase, Frank and Frey, Matthias and Dubravica, Darko and Blumenstock, Thomas and Dehn, Angelika and Castracane, Paolo and Surawicz, Gregor and Harig, Roland and Baier, Bianca C. and Bès, Caroline and Bi, Jianrong and Boesch, Hartmut and Butz, André and Cai, Zhaonan and Chen, Jia and Crowell, Sean M. and Deutscher, Nicholas M. and Ene, Dragos and Franklin, Jonathan E. and García, Omaira and Griffith, David and Grouiez, Bruno and Grutter, Michel and Hamdouni, Abdelhamid and Houweling, Sander and Humpage, Neil and Jacobs, Nicole and Jeong, Sujong and Joly, Lilian and Jones, Nicholas B. and Jouglet, Denis and Kivi, Rigel and Kleinschek, Ralph and Lopez, Morgan and Medeiros, Diogo J. and Morino, Isamu and Mostafavipak, Nasrin and Müller, Astrid and Ohyama, Hirofumi and Palmer, Paul I. and Pathakoti, Mahesh and Pollard, David F. and Raffalski, Uwe and Ramonet, Michel and Ramsay, Robbie and Sha, Mahesh Kumar and Shiomi, Kei and Simpson, William and Stremme, Wolfgang and Sun, Youwen and Tanimoto, Hiroshi and Té, Yao and Tsidu, Gizaw Mengistu and Velazco, Voltaire A. and Vogel, Felix and Watanabe, Masataka and Wei, Chong and Wunch, Debra and Yamasoe, Marcia and Zhang, Lu and Orphal, Johannes},
  month = apr,
  year = {2022},
  note = {Publisher: Copernicus GmbH},
  pages = {2433--2463},
  file = {Full Text PDF:/home/lena/Zotero/storage/YYY8PQ94/Alberti et al. - 2022 - Improved calibration procedures for the EM27SUN s.pdf:application/pdf;Snapshot:/home/lena/Zotero/storage/EZWJF2MX/2022.html:text/html},
}

@article{Tu:2022,
  title = {Quantification of {CH}$_{\textrm{4}}$ emissions from waste disposal sites near the city of {Madrid} using ground- and space-based observations of {COCCON}, {TROPOMI} and {IASI}},
  volume = {22},
  issn = {1680-7316},
  url = {https://acp.copernicus.org/articles/22/295/2022/},
  doi = {10.5194/acp-22-295-2022},
  abstract = {The objective of this study is to derive methane (CH4) emissions from three landfills, which are found to be the most significant CH4 sources in the metropolitan area of Madrid in Spain. We derive CH4 emissions from the CH4 enhancements observed by spaceborne and ground-based instruments. We apply satellite-based measurements from the TROPOspheric Monitoring Instrument (TROPOMI) and the Infrared Atmospheric Sounding Interferometer (IASI) together with measurements from the ground-based COllaborative Carbon Column Observing Network (COCCON) instruments.

 In 2018, a 2-week field campaign for measuring the atmospheric concentrations of greenhouse gases was performed in Madrid in the framework of Monitoring of the Greenhouse Gases Concentrations in Madrid (MEGEI-MAD) project. Five COCCON instruments were deployed at different locations around the Madrid city center, enabling the observation of total column-averaged CH4 mixing ratios (XCH4). Considering the prevalent wind regimes, we calculate the wind-assigned XCH4 anomalies for two opposite wind directions. Pronounced bipolar plumes are found when applying the method to NO2, which implies that our method of wind-assigned anomaly is suitable to estimate enhancements of trace gases at the urban level from satellite-based measurements. For quantifying the CH4 emissions, the wind-assigned plume method is applied to the TROPOMI XCH4 and to the lower tropospheric CH4 / dry-air column ratio (TXCH4) of the combined TROPOMI+IASI product.

 As CH4 emission strength we estimate 7.4 × 1025 ± 6.4 × 1024 molec. s−1 from the TROPOMI XCH4 data and 7.1 × 1025 ± 1.0 × 1025 molec. s−1 from the TROPOMI+IASI merged TXCH4 data. We use COCCON observations to estimate the local source strength as an independent method. COCCON observations indicate a weaker CH4 emission strength of 3.7 × 1025 molec. s−1 from a local source (the Valdemingómez waste plant) based on observations from a single day. This strength is lower than the one derived from the satellite observations, and it is a plausible result. This is because the analysis of the satellite data refers to a larger area, covering further emission sources in the study region, whereas the signal observed by COCCON is generated by a nearby local source. All emission rates estimated from the different observations are significantly larger than the emission rates provided via the official Spanish Register of Emissions and Pollutant Sources.},
  language = {English},
  number = {1},
  urldate = {2023-03-02},
  journal = {Atmospheric Chemistry and Physics},
  author = {Tu, Qiansi and Hase, Frank and Schneider, Matthias and García, Omaira and Blumenstock, Thomas and Borsdorff, Tobias and Frey, Matthias and Khosrawi, Farahnaz and Lorente, Alba and Alberti, Carlos and Bustos, Juan J. and Butz, André and Carreño, Virgilio and Cuevas, Emilio and Curcoll, Roger and Diekmann, Christopher J. and Dubravica, Darko and Ertl, Benjamin and Estruch, Carme and León-Luis, Sergio Fabián and Marrero, Carlos and Morgui, Josep-Anton and Ramos, Ramón and Scharun, Christian and Schneider, Carsten and Sepúlveda, Eliezer and Toledano, Carlos and Torres, Carlos},
  month = jan,
  year = {2022},
  note = {Publisher: Copernicus GmbH},
  pages = {295--317},
  file = {Full Text PDF:/home/lena/Zotero/storage/PSN4JRHZ/Tu et al. - 2022 - Quantification of CH4 emissions from wa.pdf:application/pdf},
}

@article{Hase:2016,
  title = {Addition of a channel for {XCO} observations to a portable {FTIR} spectrometer for greenhouse gas measurements},
  volume = {9},
  issn = {1867-1381},
  url = {https://amt.copernicus.org/articles/9/2303/2016/},
  doi = {10.5194/amt-9-2303-2016},
  abstract = {The portable FTIR (Fourier transform infrared) spectrometer EM27/SUN, dedicated to the precise and accurate observation of column-averaged abundances of methane and carbon dioxide, has been equipped with a second detector channel, which allows the detection of additional species, especially carbon monoxide. This allows an improved characterisation of observed carbon dioxide enhancements and makes the extended spectrometer especially suitable as a validation tool of ESA's Sentinel 5 Precursor mission, as it now covers the same spectral region as used by the infrared channel of the TROPOMI (TROPOspheric Monitoring Instrument) sensor. The extension presented here does not rely on a dichroic, but instead a fraction of the solar beam is decoupled near the aperture stop of the spectrometer using a small plane mirror. This approach allows maintaining the camera-controlled solar tracker set-up, which is referenced to the field stop in front of the primary detector. Moreover, the upgrade of existing instruments can be performed without alterating the optical set-up of the primary channel and resulting changes of the instrumental characteristics of the original instrument.},
  language = {English},
  number = {5},
  urldate = {2023-04-20},
  journal = {Atmospheric Measurement Techniques},
  author = {Hase, Frank and Frey, Matthias and Kiel, Matthäus and Blumenstock, Thomas and Harig, Roland and Keens, Axel and Orphal, Johannes},
  month = may,
  year = {2016},
  note = {Publisher: Copernicus GmbH},
  pages = {2303--2313},
  file = {Full Text PDF:/home/lena/Zotero/storage/R9UVDPGK/Hase et al. - 2016 - Addition of a channel for XCO observations to a po.pdf:application/pdf},
}

@article{Dietrich:2021,
  title = {{MUCCnet}: {Munich} {Urban} {Carbon} {Column} network},
  volume = {14},
  issn = {1867-1381},
  shorttitle = {{MUCCnet}},
  url = {https://amt.copernicus.org/articles/14/1111/2021/},
  doi = {10.5194/amt-14-1111-2021},
  abstract = {In order to mitigate climate change, it is crucial to understand urban greenhouse gas (GHG) emissions precisely, as more than two-thirds of the anthropogenic GHG emissions worldwide originate from cities. Nowadays, urban emission estimates are mainly based on bottom-up calculation approaches with high uncertainties. A reliable and long-term top-down measurement approach could reduce the uncertainty of these emission inventories significantly.

 We present the Munich Urban Carbon Column network (MUCCnet), the world's first urban sensor network, which has been permanently measuring GHGs, based on the principle of differential column measurements (DCMs), since summer 2019. These column measurements and column concentration differences are relatively insensitive to vertical redistribution of tracer masses and surface fluxes upwind of the city, making them a favorable input for an inversion framework and, therefore, a well-suited candidate for the quantification of GHG emissions.

 However, setting up such a stationary sensor network requires an automated measurement principle. We developed our own fully automated enclosure systems for measuring column-averaged CO2, CH4 and CO concentrations with a solar-tracking Fourier transform spectrometer (EM27/SUN) in a fully automated and long-term manner. This also includes software that starts and stops the measurements autonomously and can be used independently from the enclosure system.

 Furthermore, we demonstrate the novel applications of such a sensor network by presenting the measurement results of our five sensor systems that are deployed in and around Munich. These results include the seasonal cycle of CO2 since 2015, as well as concentration gradients between sites upwind and downwind of the city. Thanks to the automation, we were also able to continue taking measurements during the COVID-19 lockdown in spring 2020. By correlating the CO2 column concentration gradients to the traffic amount, we demonstrate that our network is capable of detecting variations in urban emissions.

 The measurements from our unique sensor network will be combined with an inverse modeling framework that we are currently developing in order to monitor urban GHG emissions over years, identify unknown emission sources and assess how effective the current mitigation strategies are. In summary, our achievements in automating column measurements of GHGs will allow researchers all over the world to establish this approach for long-term greenhouse gas monitoring in urban areas.},
  language = {English},
  number = {2},
  urldate = {2023-04-25},
  journal = {Atmospheric Measurement Techniques},
  author = {Dietrich, Florian and Chen, Jia and Voggenreiter, Benno and Aigner, Patrick and Nachtigall, Nico and Reger, Björn},
  month = feb,
  year = {2021},
  note = {Publisher: Copernicus GmbH},
  pages = {1111--1126},
  file = {Full Text PDF:/home/lena/Zotero/storage/QY3RRGEC/Dietrich et al. - 2021 - MUCCnet Munich Urban Carbon Column network.pdf:application/pdf},
}

