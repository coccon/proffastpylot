@article{Gisi:2011,
  title = {Camtracker: a new camera controlled high precision solar tracker system for {FTIR}-spectrometers},
  volume = {4},
  issn = {1867-8548},
  shorttitle = {Camtracker},
  url = {https://amt.copernicus.org/articles/4/47/2011/},
  doi = {10.5194/amt-4-47-2011},
  abstract = {Abstract. A new system to very precisely couple radiation of a moving source into a Fourier Transform Infrared (FTIR) Spectrometer is presented. The Camtracker consists of a homemade altazimuthal solar tracker, a digital camera and a homemade program to process the camera data and to control the motion of the tracker. The key idea is to evaluate the image of the radiation source on the entrance field stop of the spectrometer. We prove that the system reaches tracking accuracies of about 10 arc s for a ground-based solar absorption FTIR spectrometer, which is significantly better than current solar trackers. Moreover, due to the incorporation of a camera, the new system allows to document residual pointing errors and to point onto the solar disk center even in case of variable intensity distributions across the source due to cirrus or haze.},
  language = {en},
  number = {1},
  urldate = {2022-02-22},
  journal = {Atmospheric Measurement Techniques},
  author = {Gisi, M. and Hase, F. and Dohe, S. and Blumenstock, T.},
  month = jan,
  year = {2011},
  pages = {47--54},
  file = {Full Text:/home/lena/Zotero/storage/48V99Y6B/Gisi et al. - 2011 - Camtracker a new camera controlled high precision.pdf:application/pdf},
}

